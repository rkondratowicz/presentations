---
// Full-bleed quote / big-statement slide.
interface Props {
  cite?: string;
}
const { cite } = Astro.props;
---

<section class="slide slide--quote">
  <figure>
    <blockquote><slot /></blockquote>
    {cite && <figcaption>— {cite}</figcaption>}
  </figure>
</section>

<style>
  .slide--quote {
    background: var(--surface);
  }
  figure {
    margin: 0;
  }
  blockquote {
    font-family: var(--font-display);
    font-size: var(--step-h2);
    line-height: 1.15;
    letter-spacing: -0.02em;
    text-wrap: balance;
    margin: 0;
    max-width: 22ch;
  }
  figcaption {
    margin-top: var(--space-3);
    font-size: var(--step-h3);
    color: var(--ink-muted);
  }
</style>
